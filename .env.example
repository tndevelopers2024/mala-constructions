# Mala Constructions — Environment Variables
# Copy this file to .env.local and fill in real values

# SMTP (for contact form email delivery)
# Use Gmail App Password — NOT your main Gmail password
# To generate: Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=malaconstructionschennai@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Alternatively, use Resend (https://resend.com) by swapping
# the nodemailer transport in /src/app/api/enquiry/route.ts
# RESEND_API_KEY=re_xxxxxxxxxxxx
